<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>MONGLE_OS // ARCHIVE_MANAGER</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
        :root { --primary: #00ff41; --bg: #050505; --card: #0f0f0f; --text-dim: #555; }
        body { background: var(--bg); color: var(--primary); font-family: 'Share Tech Mono', monospace; padding: 50px 20px; display: flex; flex-direction: column; align-items: center; }
        .timeline { position: relative; max-width: 700px; width: 100%; border-left: 2px solid #1a1a1a; padding-left: 40px; }
        .header { width: 100%; max-width: 700px; margin-bottom: 40px; border-bottom: 1px solid var(--primary); padding-bottom: 10px; }
        .v-card { background: var(--card); border: 1px solid #222; margin-bottom: 30px; padding: 20px; border-radius: 8px; position: relative; transition: 0.3s; }
        .v-card:hover { border-color: var(--primary); transform: translateX(5px); }
        .v-card::before { content: ''; position: absolute; left: -47px; top: 25px; width: 12px; height: 12px; background: var(--bg); border: 2px solid var(--primary); border-radius: 50%; }
        .v-name { font-size: 22px; color: #fff; display: block; }
        .v-desc { color: #888; font-size: 14px; margin: 10px 0; line-height: 1.4; }
        .v-date { font-size: 10px; color: var(--text-dim); text-transform: uppercase; }
        .btn { display: inline-block; margin-top: 15px; padding: 8px 20px; border: 1px solid var(--primary); color: var(--primary); text-decoration: none; font-size: 12px; transition: 0.2s; cursor: pointer; }
        .btn:hover { background: var(--primary); color: #000; }
    </style>
</head>
<body>

    <div class="header">
        <h1>PROJECT_EVOLUTION</h1>
        <div id="welcom this is the evolution of mongle from the begening to the end" style="font-size: 10px; opacity: 0.5;">welcom this is the evolution of mongle from the begening to the end</div>
    </div>

    <div class="timeline" id="timeline">
        </div>

<script>
    /* ==========================================
       MANAGE YOUR VERSIONS HERE
       ========================================== */
    const VERSION_REGISTRY = [
        {
            fileName: "tech work Feb 23 better.html",
            displayName: "v6 MONGLE_OS",
            description: "The first stable build. Features the basic 404 ghost-login and initial game grid layout.",
            date: "MARCH 2"
        },
        {
            fileName: "v7 thets go.html",
            displayName: "v7 MONGLE_OS",
            description: "Introduction of the global presence system, updated game logic, and refined admin triggers.",
            date: "MARCH 5"
        },
        {
            fileName: "v8 bru.html",
            displayName: "MONGLE_OS v8",
            description: "Latest stable release. Added Matrix lockdown animations, Rajdhani fonts, and the new Mongle Admin suite.",
            date: "march 17"
        }
    ];

    const GITHUB_CONFIG = {
        user: 'Idonotknowhowtocodeyet',
        repo: 'turbo-octo-barnacle',
        branch: 'main'
    };

    /* ==========================================
       LOGIC (Don't touch unless you want to change how it works)
       ========================================== */
    function renderCatalog() {
        const container = document.getElementById('timeline');
        container.innerHTML = '';

        VERSION_REGISTRY.forEach(version => {
            const githack = `https://raw.githack.com/${GITHUB_CONFIG.user}/${GITHUB_CONFIG.repo}/${GITHUB_CONFIG.branch}/${version.fileName}`;
            
            const card = document.createElement('div');
            card.className = 'v-card';
            card.innerHTML = `
                <span class="v-date">${version.date}</span>
                <span class="v-name">${version.displayName}</span>
                <p class="v-desc">${version.description}</p>
                <a href="${githack}" target="_blank" class="btn">INITIALIZE_BOOT</a>
            `;
            container.appendChild(card);
        });
    }

    renderCatalog();
</script>

</body>
</html>
